# Copy to config/runtime.env for local use. Do not commit real secrets.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-120b:free

# Project root. Keep the default local path unless the workspace is moved.
AVATAR_SYSTEM_ROOT=/scratch/e1554543/avatar_system_full
PROJECT_ROOT=/scratch/e1554543/avatar_system_full

# Web ports
HOST=0.0.0.0
PORT=7861

# Worker ports
TTS_WORKER_HOST=127.0.0.1
TTS_WORKER_PORT=8788
AVAMERG_WORKER_HOST=127.0.0.1
AVAMERG_WORKER_PORT=8789
DEEPTALK_WORKER_HOST=127.0.0.1
DEEPTALK_WORKER_PORT=8790
PERCEPTION_WORKER_HOST=127.0.0.1
PERCEPTION_WORKER_PORT=8791
GAUSSIAN_RENDER_WORKER_HOST=127.0.0.1
GAUSSIAN_RENDER_WORKER_PORT=8792

# Optional service switches
START_TTS_WORKER=1
START_AVAMERG_WORKER=1
START_DEEPTALK_WORKER=1
START_PERCEPTION_WORKER=1
START_GAUSSIAN_RENDER_WORKER=1

# Booth / 3DEPB
BOOTH_DEFAULT_ROUTE=1
DEPB_ROOT=/scratch/e1554543/avatar_system_full/3DEPB_runs/3DEPB
